        <!-- Nota explicativa -->
        <mxCell id="note1" value="&lt;b&gt;Patrón Strategy:&lt;/b&gt;&#xa;El LLMContext mantiene una referencia&#xa;a ILLMStrategy. En tiempo de ejecución,&#xa;se selecciona OllamaStrategy o&#xa;LMStudioStrategy según la configuración.&#xa;Se puede cambiar la estrategia sin&#xa;modificar el contexto." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
